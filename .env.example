# Required: Anthropic (Planning + Security Audit)
ANTHROPIC_API_KEY=sk-ant-...

# Required: Google AI (Gemini Flash for quick tasks)
GOOGLE_AI_API_KEY=AI...

# Required: DeepSeek (Budget code gen + Reasoning)
DEEPSEEK_API_KEY=sk-...

# Required: Alibaba DashScope (Qwen for debugging + boilerplate)
DASHSCOPE_API_KEY=sk-...

# Required: Moonshot Kimi (Frontend visual synthesis)
KIMI_API_KEY=sk-...
